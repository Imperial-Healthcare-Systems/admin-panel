# =====================================================================
# Imperial Admin Console — Environment Variables (Section 1 of bible)
# =====================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real secrets.

# ---- Supabase (shared with IHRMS + ICRM) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- NextAuth ----
# Generate: openssl rand -base64 32  (MUST be different from IHRMS / ICRM secrets)
NEXTAUTH_SECRET=
# Decision Gate #1: apex domain
NEXTAUTH_URL=https://imperialhealthcare.cloud

# ---- Cron auth ----
# Generate: openssl rand -hex 32
CRON_SECRET=

# ---- Impersonation (signs short-lived JWTs to log into IHRMS / ICRM as a customer) ----
# Generate: openssl rand -hex 64. The same value MUST be set in IHRMS + ICRM env so they can verify.
IMPERSONATION_SECRET=

# ---- SMTP (Resend) ----
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=Imperial Admin <admin@imperialhealthcare.cloud>

# ---- Cashfree (refund operations) ----
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_BASE=https://api.cashfree.com

# ---- OpenAI (vendor cost monitoring) ----
OPENAI_API_KEY=

# ---- Upstash Redis (rate limiting on admin routes — Section 8) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Cross-app links (impersonation target URLs, Section 6.3) ----
IHRMS_BASE_URL=https://imperialhrms.com
ICRM_BASE_URL=https://imperialcrm.cloud

# ---- Imperial org slug check (Section 4.1) ----
# Defaults baked in: 'imperial-healthcare-systems' OR 'imperial'.
# Override here only if your org row uses a different slug.
IMPERIAL_ORG_SLUG=imperial-healthcare-systems
